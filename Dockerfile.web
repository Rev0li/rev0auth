# ── Build ──────────────────────────────────────────────────────────────────────
FROM rust:slim AS builder
WORKDIR /build

RUN apt-get update \
 && apt-get install -y --no-install-recommends pkg-config libssl-dev \
 && rm -rf /var/lib/apt/lists/*

# Layer: resolve workspace (changes rarely)
COPY Cargo.toml Cargo.lock ./
COPY crates/api/Cargo.toml crates/api/Cargo.toml
COPY crates/web/Cargo.toml crates/web/Cargo.toml

# Stub sources so cargo can resolve the full workspace graph
RUN mkdir -p crates/api/src crates/web/src \
 && printf 'fn main(){}' > crates/api/src/main.rs \
 && printf 'fn main(){}' > crates/web/src/main.rs

# Layer: compile dependencies only (cached unless Cargo.toml/Cargo.lock change)
RUN cargo build --release -p rev0auth-web \
 && rm -f target/release/deps/rev0auth_web* target/release/rev0auth-web

# Layer: real sources (migrations embedded at compile time via sqlx::migrate!)
COPY crates/api/migrations crates/api/migrations
COPY crates/web/src crates/web/src
RUN touch crates/web/src/main.rs \
 && cargo build --release -p rev0auth-web

# ── Runtime ────────────────────────────────────────────────────────────────────
FROM debian:trixie-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates libssl3 wget \
 && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/rev0auth-web /usr/local/bin/rev0auth-web

# Static assets read at runtime via relative path (static/hero/)
WORKDIR /app
COPY static /app/static

EXPOSE 3000
CMD ["/usr/local/bin/rev0auth-web"]
