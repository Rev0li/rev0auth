# Copy to /etc/caddy/rev0auth-caddy.env on the VPS (chmod 600)

# ── Web portal (tout le site : auth + membres + admin) ───────────────────────
WEB_DOMAIN=auth.rev0univers.com
FRONTEND_UPSTREAM=127.0.0.1:4173

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
ACME_EMAIL=you@example.com
CADDY_LOG_LEVEL=INFO
