# Copy to /etc/caddy/rev0auth-caddy.env
API_DOMAIN=api.revoli.duckdns.org
# If 8080 is already used on this host (e.g. Songsurf), move API to another local port
# and keep Caddy in sync with API_BIND_ADDR / REV0AUTH_API_UPSTREAM.
API_UPSTREAM=127.0.0.1:8080
# Example conflict-free setup:
# API_UPSTREAM=127.0.0.1:18080
ACME_EMAIL=admin@example.com
CADDY_LOG_LEVEL=INFO
