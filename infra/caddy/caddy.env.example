# Copy to /etc/caddy/rev0auth-caddy.env on the VPS (chmod 600)

# ── Web portal (auth + member zone) ──────────────────────────────────────────
WEB_DOMAIN=auth.rev0univers.com
WEB_UPSTREAM=127.0.0.1:3000

# ── API (leave disabled if API is internal-only) ──────────────────────────────
# Set API_DOMAIN only if SongSurf or external clients need direct API access.
# If internal-only: comment out the API block in Caddyfile.template.
API_DOMAIN=api.rev0univers.com
API_UPSTREAM=127.0.0.1:8080

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
ACME_EMAIL=you@example.com
CADDY_LOG_LEVEL=INFO
