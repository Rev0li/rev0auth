# PostgreSQL connection (shared with Rust web crate)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rev0auth

# Session secret — min 32 chars, random
SESSION_SECRET=change_me_at_least_32_chars_long_xxx

# Admin credentials
ADMIN_DASH_PASSWORD=
ADMIN_DASH_PSEUDO=admin
ADMIN_DASH_SEED=
ADMIN_DASH_TOTP_SECRET=

# Upstream Rust web (rev0auth-web) — used to proxy WebAuthn admin
REV0AUTH_WEB_UPSTREAM=http://127.0.0.1:3000

# SongSurf JWT (must match SongSurf server config)
SONGSURF_JWT_SECRET=
SONGSURF_URL=

# Port override (default: 3000)
# PORT=3000
