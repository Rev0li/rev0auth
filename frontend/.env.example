# SQLite database file path
DB_PATH=./data/rev0auth.db

# Session secret — min 32 chars, random
SESSION_SECRET=change_me_at_least_32_chars_long_xxx

# Admin credentials (mirrored from root .env for the web layer)
ADMIN_DASH_PASSWORD=
ADMIN_DASH_PSEUDO=admin
ADMIN_DASH_SEED=
ADMIN_DASH_TOTP_SECRET=

# Upstream API (rev0auth-api, optional for Phase 2)
REV0AUTH_API_UPSTREAM=http://127.0.0.1:8080

# Port override (default: 3000)
# PORT=3000
