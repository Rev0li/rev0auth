# PostgreSQL connection (shared with Rust web crate)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rev0auth

# Admin credentials
ADMIN_DASH_PASSWORD=
ADMIN_DASH_PSEUDO=admin
ADMIN_DASH_SEED=
ADMIN_DASH_TOTP_SECRET=

# Upstream Rust API — health check (default: 127.0.0.1:8080)
REV0AUTH_API_UPSTREAM=127.0.0.1:8080

# Upstream Rust web — WebAuthn proxy (default: http://127.0.0.1:3000)
REV0AUTH_WEB_UPSTREAM=http://127.0.0.1:3000

# SongSurf integration
# AUTH_JWT_SECRET — secret unique pour tous les JWT SongSurf (handoff, logs, login)
#                   doit matcher AUTH_JWT_SECRET dans SongSurf/.secrets
#                   (SONGSURF_JWT_SECRET est encore lu en fallback legacy, à ne plus définir)
# SONGSURF_URL    — SongSurf watcher public URL (e.g. https://rev0lisurf.duckdns.org/)
AUTH_JWT_SECRET=
SONGSURF_URL=

# BetterAuth (Phase 2) — secret de signature des sessions
# Fallback sur AUTH_JWT_SECRET si non défini
# BETTER_AUTH_SECRET=

# Donations — crypto addresses (format: "Name:address,Name2:address2")
# Leave empty for "À configurer" fallback
DONATION_CRYPTO_ADDRESSES=

# Port override (default: 3000 in preview, 5173 in dev)
# PORT=3000
