# Copy to .env on VPS and fill from your vault/secrets manager
POSTGRES_PASSWORD=change-me-strong-password
AUTH_JWT_SECRET=replace-with-32-bytes-minimum-secret
DATABASE_URL=postgres://postgres:change-me-strong-password@postgres:5432/rev0auth

ADMIN_DASH_PASSWORD='prod-pasword'
ADMIN_DASH_PSEUDO='pseudoadmin'
ADMIN_DASH_SEED='secret-seed'
# Optional: enable admin 2FA TOTP (Base32 secret, ex from authenticator setup)
ADMIN_DASH_TOTP_SECRET=''

# Cross-domain cookie sharing with SongSurf (leave empty for local dev)
# Set to your root domain so the access_token cookie reaches SongSurf on a subdomain.
# Example prod: COOKIE_DOMAIN=.rev0univers.com
# Local dev:    COOKIE_DOMAIN=   (empty — cookie stays on localhost)
COOKIE_DOMAIN=''

# SvelteKit — domaine public pour adapter-node (protection CSRF)
ORIGIN=https://auth.rev0univers.com

# URL du bouton "Ouvrir Songsurf" affiché aux membres autorisés.
# Local dev : http://localhost:9000
# Tailscale : http://<ip-tailscale>:9000  ou  https://songsurf.xxx.ts.net
SONGSURF_URL='http://localhost:9000'

# Crypto donation addresses shown to members (format: NAME:ADDRESS,NAME:ADDRESS,...)
# Example: DONATION_CRYPTO_ADDRESSES=Bitcoin:bc1qxxx...,Ethereum:0xyyy...,Monero:zzz...
DONATION_CRYPTO_ADDRESSES=''
