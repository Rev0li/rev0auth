# Copy to .env on VPS and fill from your vault/secrets manager
POSTGRES_PASSWORD=change-me-strong-password
AUTH_JWT_SECRET=replace-with-32-bytes-minimum-secret
DATABASE_URL=postgres://postgres:change-me-strong-password@postgres:5432/rev0auth

ADMIN_DASH_PASSWORD='prod-pasword'
ADMIN_DASH_PSEUDO='pseudoadmin'
ADMIN_DASH_SEED='secret-seed'
# Optional: enable admin 2FA TOTP (Base32 secret, ex from authenticator setup)
ADMIN_DASH_TOTP_SECRET=''
